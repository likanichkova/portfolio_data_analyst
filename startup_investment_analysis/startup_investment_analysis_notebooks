    "    return 'More than 1 year'\n",
    "\n",
    "df_funding['funding_period'] = df_funding.apply(funding_group, axis=1)\n",
    "\n",
    "period_order = ['Single round', 'Up to 1 year', 'More than 1 year']\n",
    "\n",
    "period_colors = {\n",
